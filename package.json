{
	"name": "whconvertracker-server-bun",
	"version": "1.0.50",
	"type": "module",
	"module": "src/index.js",
	"scripts": {
		"db:generate": "dotenv -e .env -- prisma generate",
		"db:migrate": "dotenv -e .env -- prisma migrate dev",
		"db:deploy": "dotenv -e .env -- prisma migrate deploy",
		"db:push": "dotenv -e .env -- prisma db push --accept-data-loss",
		"typecheck": "bunx tsc --noEmit",
		"format": "oxfmt src prisma.config.ts types",
		"format:check": "oxfmt --check src prisma.config.ts types",
		"lint": "oxlint -c ./.oxlintrc.json --tsconfig ./tsconfig.json --ignore-path ./.eslintignore src prisma.config.ts types",
		"lint:fix": "oxlint -c ./.oxlintrc.json --tsconfig ./tsconfig.json --ignore-path ./.eslintignore --fix src prisma.config.ts types",
		"test": "echo \"Error: no test specified\" && exit 1",
		"dev": "bun run --watch src/index.ts",
		"build": "bun run typecheck && bun run lint && bun build --production --target=bun --bytecode --outdir=./dist src/index.ts",
		"start": "dotenv -e .env bun ./dist/index.js"
	},
	"dependencies": {
		"@elysia/cors": "^1.4.2",
		"@elysia/jwt": "^1.4.2",
		"@elysia/server-timing": "^1.4.1",
		"@elysiajs/openapi": "^1.4.15",
		"@logtape/elysia": "^2.1.1",
		"@logtape/file": "^2.1.1",
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"@types/mime-types": "^3.0.1",
		"arctic": "^3.7.0",
		"dayjs": "^1.11.21",
		"dotenv": "^17.4.2",
		"elysia": "^1.4.28",
		"elysia-http-exception": "^0.1.5",
		"elysia-oauth2": "^2.1.0",
		"elysia-remote-dts": "^1.0.3",
		"mime-types": "^3.0.2",
		"pg": "^8.21.0"
	},
	"devDependencies": {
		"bun-types": "^1.3.14",
		"dotenv-cli": "^11.0.0",
		"oxfmt": "^0.53.0",
		"oxlint": "^1.68.0",
		"prisma": "^7.8.0",
		"prismabox": "^1.1.26",
		"typescript": "^6.0.3"
	}
}
